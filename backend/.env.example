# Which AI provider to use for field mapping: "openai" | "gemini" | "anthropic"
AI_PROVIDER=openai

# Only the key matching AI_PROVIDER is required
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Server
PORT=4000

# How many CSV rows to send to the AI per request
BATCH_SIZE=20

# Max parallel batch requests in flight at once
BATCH_CONCURRENCY=3

# Retry attempts per batch if the AI call fails or returns invalid JSON
BATCH_MAX_RETRIES=2
